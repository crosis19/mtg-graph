# ── API Endpoints ──
SCRYFALL_BULK_URL=https://api.scryfall.com/bulk-data

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
SEMANTIC_SIMILARITY_THRESHOLD=0.65

# ── Scraper Rate Limiting (seconds between requests) ──
SCRAPE_DELAY=2.0

# ── Graph Construction ──
COUNTERS_WIN_RATE_THRESHOLD=55.0

# ── Model Architecture ──
HIDDEN_DIM=128
NUM_HEADS=4
NUM_HGT_LAYERS=3

# ── Training ──
WEIGHT_DECAY=0.0001
TRAIN_SPLIT_RATIO=0.6
VAL_SPLIT_RATIO=0.2
# Test split = 1.0 - TRAIN_SPLIT_RATIO - VAL_SPLIT_RATIO = 0.2

# ── Deck Predictor ──
DECK_LEARNING_RATE=0.001
DECK_NUM_EPOCHS=50
DECK_DROPOUT=0.3
DECK_MIN_META_SHARE=5.0
DECK_N_NEGATIVES=50
DECK_BPR_MARGIN=1.0
DECK_PATIENCE=10
DECK_CHECKPOINT_METRIC=val_hits10
DECK_FREEZE_HGT=0
DECK_RECENCY_DAYS=30
DECK_WARMUP_EPOCHS=5
DECK_LR_SCHEDULER=cosine
