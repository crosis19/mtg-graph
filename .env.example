# ── API Endpoints ──
SCRYFALL_BULK_URL=https://api.scryfall.com/bulk-data

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
SEMANTIC_SIMILARITY_THRESHOLD=0.65

# ── Scraper Rate Limiting (seconds between requests) ──
SCRAPE_DELAY=2.0

# ── Graph Construction ──
COUNTERS_WIN_RATE_THRESHOLD=55.0
CO_OCCURRENCE_MIN_DECKS=2

# ── Model Architecture ──
HIDDEN_DIM=128
NUM_HEADS=4
NUM_HGT_LAYERS=3

# ── Training Hyperparameters ──
DROPOUT=0.2
LEARNING_RATE=0.001
WEIGHT_DECAY=0.0001
NUM_EPOCHS=100
EMERGENCE_LOSS_WEIGHT=1.0
TOP8_LOSS_WEIGHT=1.0
TEMPORAL_SPLIT_RATIO=0.75
